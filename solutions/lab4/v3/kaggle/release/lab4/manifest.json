    "batch": 128,
    "epochs": 15,
    "gp_interval": 4,
    "gp_lambda": 10,
    "betas": [
      0.0,
      0.9
    ]
  },
  "fid_real_stats": "real_inception_stats.npz",
  "fid_real_n": 5000,
  "checkpoints": {
    "unconditional": "unconditional.pkl",
    "conditional": "conditional.pkl"
  }
}